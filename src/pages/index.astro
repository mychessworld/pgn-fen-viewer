---
const title = 'PGN Chess Viewer — Демо';
---

<!DOCTYPE html>
<html lang="ru">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <meta name="color-scheme" content="light dark" />
        <title>{title}</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="stylesheet" href="/css/styles.css" />
    </head>
    <body>
        <header class="header">
            <div class="container header-inner">
                <p class="header-eyebrow">Chessberry</p>
                <h1>PGN / FEN Chess Viewer</h1>
                <p class="header-lead">Просмотр партий и позиций в браузере</p>
            </div>
        </header>

        <main class="container main-content">
            <section id="demo" class="demo-section">
                <div class="demo-controls panel">
                    <div class="panel-header">
                        <h2 class="panel-title">Ввод данных</h2>
                        <div class="input-mode" role="group" aria-label="Формат ввода">
                            <button class="mode-btn active" data-mode="pgn" type="button">PGN</button>
                        </div>
                    </div>

                    <label class="field-label" for="pgn-input">Вставьте PGN/FEN</label>
                    <textarea id="pgn-input" rows="6" placeholder="1. e4 e5 2. Nf3 Nc6...">[Event "Demo"]
</textarea>

                    <div class="control-buttons">
                        <button id="load-btn" class="btn primary" type="button">Загрузить PGN</button>
                        <button id="analysis-btn" class="btn secondary" type="button" aria-pressed="false">Режим анализа</button>
                        <button id="reset-btn" class="btn tertiary" type="button">Сбросить</button>
                    </div>
                </div>

                <div id="chess-viewer" class="viewer-container obsidian-chess-plugin-container"></div>

                <div id="engine-panel" class="engine-panel hidden" aria-live="polite">
                    <div class="engine-panel-header">
                        <span class="engine-panel-title">Stockfish</span>
                        <span id="engine-depth" class="engine-depth"></span>
                    </div>
                    <div class="engine-eval-row">
                        <span id="engine-eval" class="engine-eval">—</span>
                        <span id="engine-busy" class="engine-busy"></span>
                    </div>
                    <p id="engine-line" class="engine-line">Лучшая линия появится после анализа позиции.</p>
                </div>

                <p id="viewer-status" class="viewer-status" aria-live="polite"></p>
            </section>
        </main>

        <footer class="footer">
            <div class="container footer-inner">
                <p class="footer-copy">© Chessberry</p>
                <p class="footer-links">
                    <a href="mailto:mychessworld@yahoo.com">mychessworld@yahoo.com</a>
                    <span class="footer-sep" aria-hidden="true">·</span>
                    <a href="https://www.chessberry.ru" target="_blank" rel="noopener noreferrer">www.chessberry.ru</a>
                </p>
            </div>
        </footer>

        <script is:inline src="/vendor/pgn-viewer/dist.js"></script>
        <script is:inline src="/js/demo.js"></script>
    </body>
</html>
